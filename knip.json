{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreUnresolved": ["next"],
  "workspaces": {
    ".": {
      "project": ["*.{js,ts}"],
      "ignoreDependencies": ["lint-staged"],
      "ignoreBinaries": ["typecheck", "test"]
    },
    "apps/app": {
      "entry": [
        "app/**/{page,layout,template,error,loading,not-found,route}.{ts,tsx}",
        "tests/**/*.{test,spec}.{ts,tsx}",
        "tests/e2e/**/*.spec.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "pino-pretty",
        "@tailwindcss/postcss",
        "@testing-library/user-event"
      ]
    },
    "apps/landing": {
      "entry": [
        "app/**/{page,layout,template,error,loading,not-found,route}.{ts,tsx}",
        "tests/**/*.{test,spec}.{ts,tsx}",
        "tests/e2e/**/*.spec.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "pino-pretty",
        "@tailwindcss/postcss",
        "@testing-library/user-event"
      ]
    },
    "apps/admin": {
      "entry": [
        "app/**/{page,layout,template,error,loading,not-found,route}.{ts,tsx}",
        "tests/**/*.{test,spec}.{ts,tsx}",
        "tests/e2e/**/*.spec.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "pino-pretty",
        "@tailwindcss/postcss",
        "@testing-library/user-event"
      ]
    },
    "packages/ui": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/api-client": {
      "entry": ["orval.config.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["src/generated/**"]
    }
  }
}
