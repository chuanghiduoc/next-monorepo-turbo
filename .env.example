# Root env template. Each app also has its own apps/<app>/.env.example.
# Copy the values you need into apps/<app>/.env.local (never commit .env.local).
#
# All three apps (app, admin, landing) share the same variable contract:

# This app's own public origin (browser-visible). Per app:
#   app → http://localhost:3000 · landing → http://localhost:3001 · admin → http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend base URL (server-only — never exposed to the browser).
# Browser calls are proxied through Next at /api/* and forwarded here.
BACKEND_URL=http://localhost:4000

# Pino log level (server-side): fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Dev-only: set to 1 to browse authenticated pages without a backend.
# Never enable in production — it disables the auth gate.
# PREVIEW_AUTH=1
