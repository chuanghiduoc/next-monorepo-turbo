# Frontend public URL (browser-visible)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Where the landing's CTAs send visitors — the user product app.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Backend (server-only — never exposed to browser).
# All client API calls are proxied through Next at /api/* → forwarded here.
BACKEND_URL=http://localhost:4000

# Logger (server-side only)
LOG_LEVEL=info
